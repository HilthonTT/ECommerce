@page "/catalog/{ItemId:int}"
@inject ICatalogService CatalogService
@inject ICartService CartService
@inject NavigationManager NavigationManager
@inject CartStateService CartState
@attribute [StreamRendering]

<PageTitle>@(item?.Name ?? "Product") — AdventureWorks</PageTitle>

@if (item is null && !notFound)
{
    <!-- Skeleton Loading -->
    <div class="animate-pulse">
        <div class="h-5 w-48 bg-slate-200 rounded mb-8"></div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
            <div class="aspect-square bg-slate-200 rounded-2xl"></div>
            <div class="space-y-4 py-4">
                <div class="h-4 w-24 bg-slate-200 rounded"></div>
                <div class="h-8 w-3/4 bg-slate-200 rounded"></div>
                <div class="h-4 w-1/3 bg-slate-200 rounded"></div>
                <div class="h-10 w-32 bg-slate-200 rounded mt-6"></div>
                <div class="h-px bg-slate-200 my-6"></div>
                <div class="h-4 w-full bg-slate-200 rounded"></div>
                <div class="h-4 w-5/6 bg-slate-200 rounded"></div>
                <div class="h-4 w-2/3 bg-slate-200 rounded"></div>
            </div>
        </div>
    </div>
}
else if (notFound)
{
    <!-- Not Found -->
    <div class="flex flex-col items-center justify-center py-32 text-center">
        <div class="w-20 h-20 bg-slate-100 rounded-full flex items-center justify-center mb-6">
            <svg class="w-10 h-10 text-slate-300" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="m20.25 7.5-.625 10.632a2.25 2.25 0 0 1-2.247 2.118H6.622a2.25 2.25 0 0 1-2.247-2.118L3.75 7.5m6 4.125 2.25 2.25m0 0 2.25 2.25M12 13.875l2.25-2.25M12 13.875l-2.25 2.25M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125Z" />
            </svg>
        </div>
        <h2 class="text-xl font-semibold text-slate-800">Product not found</h2>
        <p class="text-sm text-slate-500 mt-2 max-w-sm">
            The product you're looking for doesn't exist or may have been removed.
        </p>
        <button @onclick="GoBack" class="mt-6 px-5 py-2.5 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold rounded-xl transition-colors">
            Back to Catalog
        </button>
    </div>
}
else
{
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-1.5 text-sm mb-8">
        <a href="/" class="text-slate-400 hover:text-emerald-600 transition-colors">Catalog</a>
        <svg class="w-3.5 h-3.5 text-slate-300" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
        </svg>
        <a href="/?brand=@item!.CatalogBrandId" class="text-slate-400 hover:text-emerald-600 transition-colors">@item.CatalogBrand.Brand</a>
        <svg class="w-3.5 h-3.5 text-slate-300" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
        </svg>
        <span class="text-slate-700 font-medium truncate max-w-xs">@item.Name</span>
    </nav>

    <!-- Product Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-14">

        <!-- Left: Image -->
        <div class="relative">
            <div class="aspect-square bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm">
                @if (!string.IsNullOrEmpty(item!.PictureFileName))
                {
                    <img src="@CatalogService.GetPictureUrl(item.Id)"
                         alt="@item.Name"
                         class="w-full h-full object-cover" />
                }
                else
                {
                    <div class="w-full h-full flex items-center justify-center bg-slate-50">
                        <svg class="w-24 h-24 text-slate-200" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z" />
                        </svg>
                    </div>
                }
            </div>
        </div>

        <!-- Right: Details -->
        <div class="flex flex-col py-2">

            <!-- Tags -->
            <div class="flex items-center gap-2 mb-3">
                <span class="text-xs font-semibold text-emerald-700 bg-emerald-50 border border-emerald-200 px-2.5 py-1 rounded-full">
                    @item!.CatalogBrand.Brand
                </span>
                <span class="text-xs font-semibold text-slate-500 bg-slate-100 border border-slate-200 px-2.5 py-1 rounded-full">
                    @item.CatalogType.Type
                </span>
            </div>

            <!-- Title -->
            <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-900 tracking-tight leading-tight">
                @item.Name
            </h1>

            <!-- Product ID -->
            <span class="mt-2 text-xs text-slate-400 font-mono">SKU #@item.Id</span>

            <!-- Price -->
            <div class="mt-6">
                <span class="text-4xl font-extrabold text-slate-900">@item.Price.ToString("C")</span>
                <span class="ml-2 text-sm text-slate-400">tax included</span>
            </div>

            <!-- Quantity + Add to Cart -->
            <div class="mt-8 flex flex-col sm:flex-row items-stretch sm:items-center gap-3">
                <div class="flex items-center border border-slate-200 rounded-xl overflow-hidden bg-white shadow-sm">
                    <button @onclick="DecrementQuantity"
                            disabled="@(quantity <= 1 || isAddingToCart)"
                            class="w-11 h-11 flex items-center justify-center text-slate-500 hover:bg-slate-50 transition-colors disabled:opacity-30 disabled:cursor-not-allowed">
                        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14" />
                        </svg>
                    </button>
                    <span class="w-12 text-center text-sm font-semibold text-slate-800 tabular-nums">@quantity</span>
                    <button @onclick="IncrementQuantity"
                            disabled="@isAddingToCart"
                            class="w-11 h-11 flex items-center justify-center text-slate-500 hover:bg-slate-50 transition-colors disabled:opacity-30 disabled:cursor-not-allowed">
                        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                        </svg>
                    </button>
                </div>

                <button @onclick="AddToCart"
                        disabled="@isAddingToCart"
                        class="flex-1 sm:flex-none px-8 h-11 bg-emerald-600 hover:bg-emerald-700 active:bg-emerald-800 disabled:opacity-70 disabled:cursor-not-allowed text-white text-sm font-bold rounded-xl shadow-sm shadow-emerald-600/20 hover:shadow-emerald-600/30 transition-all flex items-center justify-center gap-2">
                    @if (isAddingToCart)
                    {
                        <svg class="w-4 h-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                        </svg>
                        <span>Adding…</span>
                    }
                    else
                    {
                        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007ZM8.625 10.5a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm7.5 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
                        </svg>
                        <span>Add to Cart</span>
                    }
                </button>
            </div>

            <!-- Feedback -->

            @if (IsInCart && !showAddedConfirmation)
            {
                <div class="mt-3 flex items-center justify-between p-3 bg-emerald-50 border border-emerald-200 rounded-xl">
                    <div class="flex items-center gap-2 text-sm text-emerald-700 font-medium">
                        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                        </svg>
                        Already in cart — @ExistingCartItem!.Quantity in bag
                    </div>
                    <div class="flex items-center gap-3">
                        <a href="/cart" class="text-sm text-emerald-600 hover:text-emerald-700 font-semibold underline underline-offset-2">
                            View Cart
                        </a>
                        <button @onclick="RemoveFromCart"
                                disabled="@isAddingToCart"
                                class="text-sm text-red-500 hover:text-red-600 font-semibold disabled:opacity-50">
                            Remove
                        </button>
                    </div>
                </div>
            }

            @if (showAddedConfirmation)
            {
                <div class="mt-3 flex items-center gap-2 text-sm text-emerald-600 font-medium">
                    <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                    </svg>
                    Added to cart
                    <span class="text-slate-300 mx-1">·</span>
                    <a href="/cart" class="text-emerald-600 hover:text-emerald-700 underline underline-offset-2">View Cart</a>
                </div>
            }

            @if (!string.IsNullOrEmpty(cartError))
            {
                <div class="mt-3 flex items-center gap-2 text-sm text-red-500 font-medium">
                    <svg class="w-4 h-4 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
                    </svg>
                    @cartError
                </div>
            }

            <!-- Divider -->
            <div class="border-t border-slate-200 mt-8 pt-8"></div>

            <!-- Description -->
            @if (!string.IsNullOrEmpty(item.Description))
            {
                <div>
                    <h2 class="text-sm font-bold text-slate-500 uppercase tracking-widest mb-3">Description</h2>
                    <p class="text-base text-slate-600 leading-relaxed">
                        @item.Description
                    </p>
                </div>
            }

            <!-- Details Grid -->
            <div class="mt-8">
                <h2 class="text-sm font-bold text-slate-500 uppercase tracking-widest mb-4">Details</h2>
                <dl class="grid grid-cols-2 gap-x-6 gap-y-4">
                    <div>
                        <dt class="text-xs text-slate-400 font-medium">Brand</dt>
                        <dd class="text-sm text-slate-800 font-semibold mt-0.5">@item.CatalogBrand.Brand</dd>
                    </div>
                    <div>
                        <dt class="text-xs text-slate-400 font-medium">Category</dt>
                        <dd class="text-sm text-slate-800 font-semibold mt-0.5">@item.CatalogType.Type</dd>
                    </div>
                    <div>
                        <dt class="text-xs text-slate-400 font-medium">Product ID</dt>
                        <dd class="text-sm text-slate-800 font-mono mt-0.5">@item.Id</dd>
                    </div>
                    <div>
                        <dt class="text-xs text-slate-400 font-medium">Availability</dt>
                        <dd class="text-sm text-emerald-600 font-semibold mt-0.5 flex items-center gap-1.5">
                            <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full"></span>
                            In Stock
                        </dd>
                    </div>
                </dl>
            </div>

            <!-- Policies -->
            <div class="mt-8 grid grid-cols-1 sm:grid-cols-3 gap-4">
                <div class="flex items-start gap-3 p-4 bg-slate-50 rounded-xl">
                    <svg class="w-5 h-5 text-slate-400 shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
                    </svg>
                    <div>
                        <span class="text-xs font-semibold text-slate-700 block">Free Shipping</span>
                        <span class="text-xs text-slate-400">Orders over €50</span>
                    </div>
                </div>
                <div class="flex items-start gap-3 p-4 bg-slate-50 rounded-xl">
                    <svg class="w-5 h-5 text-slate-400 shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182" />
                    </svg>
                    <div>
                        <span class="text-xs font-semibold text-slate-700 block">30-Day Returns</span>
                        <span class="text-xs text-slate-400">Hassle-free</span>
                    </div>
                </div>
                <div class="flex items-start gap-3 p-4 bg-slate-50 rounded-xl">
                    <svg class="w-5 h-5 text-slate-400 shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
                    </svg>
                    <div>
                        <span class="text-xs font-semibold text-slate-700 block">Secure Payment</span>
                        <span class="text-xs text-slate-400">SSL encrypted</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int ItemId { get; set; }

    private CartDto? cart;
    private CatalogItemDto? item;
    private bool notFound;
    private int quantity = 1;
    private bool isAddingToCart;
    private bool showAddedConfirmation;
    private string? cartError;

    private CartItemDto? ExistingCartItem =>
        cart?.Items.FirstOrDefault(i => i.ProductId == ItemId);

    private bool IsInCart => ExistingCartItem is not null;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            item = await CatalogService.GetCatalogItem(ItemId);
            if (item is null)
            {
                notFound = true;
            }

            await RefreshCart();
        }
        catch
        {
            notFound = true;
        }
    }

    private async Task RefreshCart()
    {
        cart = await CartService.GetCartAsync();
        CartState.SetItemCount(cart.Items.Sum(i => i.Quantity));
    }

    private void IncrementQuantity() => quantity++;

    private void DecrementQuantity()
    {
        if (quantity > 1)
        {
            quantity--;
        }
    }

    private async Task AddToCart()
    {
        if (item is null || isAddingToCart)
        {
            return;
        }

        cartError = null;
        isAddingToCart = true;
        showAddedConfirmation = false;

        try
        {
            var request = new AddToCartRequestDto
            {
                ProductId = item.Id,
                Quantity = quantity,
            };

            await CartService.AddToCartAsync(request);

            showAddedConfirmation = true;

            await RefreshCart();
        }
        catch (HttpRequestException)
        {
            cartError = "Could not add to cart. Please try again.";
        }
        finally
        {
            isAddingToCart = false;
        }
    }

    private async Task RemoveFromCart()
    {
        if (item is null)
        {
            return;
        }

        cartError = null;
        showAddedConfirmation = false;
        isAddingToCart = true;

        
        try
        {
            await CartService.RemoveAsync(item.Id);

            await RefreshCart();
        }
        catch (HttpRequestException)
        {
            cartError = "Could not remove from cart. Please try again.";
        }
        finally
        {
            isAddingToCart = false;
        }
    }

    private void GoBack() => NavigationManager.NavigateTo("/");
}
