@inject NavigationManager NavigationManager

<div class="h-full flex flex-col bg-slate-900">

    <!-- Brand -->
    <div class="px-5 py-5 border-b border-slate-800">
        <a href="" class="flex items-center gap-3 group">
            <div class="w-9 h-9 bg-emerald-500 rounded-lg flex items-center justify-center shadow-lg shadow-emerald-500/20 group-hover:shadow-emerald-500/40 transition-shadow">
                <svg class="w-5 h-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 0 1 .75-.75h3a.75.75 0 0 1 .75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349M3.75 21V9.349m0 0a3.001 3.001 0 0 0 3.75-.615A2.993 2.993 0 0 0 9.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 0 0 2.25 1.016c.896 0 1.7-.393 2.25-1.016A3.001 3.001 0 0 0 20.25 9.35m-16.5 0a3.004 3.004 0 0 0 2.25-5.097 3.004 3.004 0 0 0-2.25-1.003H3v5.1c0 .06 0 .12.008.18m16.492-.18S21 4.25 21 4.25h-.75a3.004 3.004 0 0 0-2.25 1.003 3.004 3.004 0 0 0 2.25 5.097" />
                </svg>
            </div>
            <div>
                <span class="text-base font-bold text-white tracking-tight">Adventure<span class="text-emerald-400">Works</span></span>
                <span class="block text-[10px] font-medium text-slate-500 uppercase tracking-widest">E-Commerce</span>
            </div>
        </a>
    </div>

    <!-- Toggle (mobile) -->
    <input type="checkbox" title="Navigation menu" class="navbar-toggler" />

    <!-- Navigation -->
    <div class="nav-scrollable flex-1 overflow-y-auto" onclick="document.querySelector('.navbar-toggler').click()">
        <nav class="flex flex-col px-3 py-4 gap-1">

            <!-- Section: Shop -->
            <span class="px-3 mb-2 text-[10px] font-bold text-slate-500 uppercase tracking-widest">Shop</span>

            <NavLink class="nav-link group flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-slate-400 hover:text-white hover:bg-slate-800/70 transition-colors [&.active]:bg-emerald-500/10 [&.active]:text-emerald-400" href="" Match="NavLinkMatch.All">
                <span class="w-8 h-8 flex items-center justify-center rounded-md bg-slate-800 group-[.active]:bg-emerald-500/20 transition-colors">
                    <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
                    </svg>
                </span>
                Catalog
            </NavLink>

            <NavLink class="nav-link group flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-slate-400 hover:text-white hover:bg-slate-800/70 transition-colors [&.active]:bg-emerald-500/10 [&.active]:text-emerald-400" href="brands">
                <span class="w-8 h-8 flex items-center justify-center rounded-md bg-slate-800 group-[.active]:bg-emerald-500/20 transition-colors">
                    <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 0 0 3 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 0 0 5.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 0 0 9.568 3Z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6Z" />
                    </svg>
                </span>
                Brands
            </NavLink>

            <NavLink class="nav-link group flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-slate-400 hover:text-white hover:bg-slate-800/70 transition-colors [&.active]:bg-emerald-500/10 [&.active]:text-emerald-400" href="categories">
                <span class="w-8 h-8 flex items-center justify-center rounded-md bg-slate-800 group-[.active]:bg-emerald-500/20 transition-colors">
                    <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25a2.25 2.25 0 0 1-2.25-2.25v-2.25Z" />
                    </svg>
                </span>
                Categories
            </NavLink>

            <!-- Divider -->
            <div class="my-3 mx-3 border-t border-slate-800"></div>

            <!-- Section: Account -->
            <span class="px-3 mb-2 text-[10px] font-bold text-slate-500 uppercase tracking-widest">Account</span>

            <NavLink class="nav-link group flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-slate-400 hover:text-white hover:bg-slate-800/70 transition-colors [&.active]:bg-emerald-500/10 [&.active]:text-emerald-400" href="cart">
                <span class="w-8 h-8 flex items-center justify-center rounded-md bg-slate-800 group-[.active]:bg-emerald-500/20 transition-colors">
                    <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
                    </svg>
                </span>
                Cart
            </NavLink>

            <NavLink class="nav-link group flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-slate-400 hover:text-white hover:bg-slate-800/70 transition-colors [&.active]:bg-emerald-500/10 [&.active]:text-emerald-400" href="orders">
                <span class="w-8 h-8 flex items-center justify-center rounded-md bg-slate-800 group-[.active]:bg-emerald-500/20 transition-colors">
                    <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15a2.25 2.25 0 0 1 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z" />
                    </svg>
                </span>
                Orders
            </NavLink>

            <NavLink class="nav-link group flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-slate-400 hover:text-white hover:bg-slate-800/70 transition-colors [&.active]:bg-emerald-500/10 [&.active]:text-emerald-400" href="tickets">
                <span class="w-8 h-8 flex items-center justify-center rounded-md bg-slate-800 group-[.active]:bg-emerald-500/20 transition-colors">
                    <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 6v.75m0 3v.75m0 3v.75m0 3V18m-9-5.25h5.25M7.5 15h3M3.375 5.25c-.621 0-1.125.504-1.125 1.125v3.026a2.999 2.999 0 0 1 0 5.198v3.026c0 .621.504 1.125 1.125 1.125h17.25c.621 0 1.125-.504 1.125-1.125v-3.026a2.999 2.999 0 0 1 0-5.198V6.375c0-.621-.504-1.125-1.125-1.125H3.375Z" />
                    </svg>
                </span>
                Tickets
            </NavLink>
        </nav>
    </div>

    <!-- User Info Footer -->
    <div class="px-3 py-4 border-t border-slate-800">
        <UserInfo />
    </div>
</div>
