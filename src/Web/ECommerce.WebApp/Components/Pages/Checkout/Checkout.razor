@page "/checkout"
@inject NavigationManager NavigationManager
@attribute [StreamRendering]

<PageTitle>Checkout — AdventureWorks</PageTitle>

<!-- Header -->
<div class="mb-8">
    <button @onclick='() => NavigationManager.NavigateTo("/cart")'
            class="flex items-center gap-1.5 text-sm text-slate-400 hover:text-emerald-600 font-medium transition-colors mb-4">
        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
        </svg>
        Back to Cart
    </button>
    <h1 class="text-2xl sm:text-3xl font-extrabold text-slate-900 tracking-tight">Checkout</h1>
</div>

<!-- Stepper -->
<nav class="mb-10">
    <ol class="flex items-center gap-2 text-sm font-medium">
        @foreach (var (label, index) in Steps.Select((s, i) => (s, i)))
        {
            <li class="flex items-center gap-2">
                <span class="@StepBadgeClass(index) w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold transition-colors">
                    @if (index < currentStep)
                    {
                        <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                        </svg>
                    }
                    else
                    {
                        @(index + 1)
                    }
                </span>
                <span class="@StepLabelClass(index) hidden sm:inline transition-colors">@label</span>
            </li>
            @if (index < Steps.Length - 1)
            {
                <div class="flex-1 h-px @(index < currentStep ? "bg-emerald-400" : "bg-slate-200") mx-1 transition-colors"></div>
            }
        }
    </ol>
</nav>

<div class="flex flex-col lg:flex-row gap-8">

    <!-- Form Area -->
    <div class="flex-1 min-w-0">

        @* ───── Step 0: Shipping ───── *@
        @if (currentStep == 0)
        {
            <div class="bg-white border border-slate-200 rounded-2xl shadow-sm p-6 sm:p-8">
                <h2 class="text-lg font-bold text-slate-900 mb-6">Shipping Address</h2>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                    <div class="sm:col-span-2">
                        <label class="@LabelClass">Email address</label>
                        <input type="email" @bind="email" placeholder="you@example.com" class="@InputClass" />
                    </div>
                    <div>
                        <label class="@LabelClass">First name</label>
                        <input type="text" @bind="firstName" placeholder="John" class="@InputClass" />
                    </div>
                    <div>
                        <label class="@LabelClass">Last name</label>
                        <input type="text" @bind="lastName" placeholder="Doe" class="@InputClass" />
                    </div>
                    <div class="sm:col-span-2">
                        <label class="@LabelClass">Street address</label>
                        <input type="text" @bind="address" placeholder="123 Main Street" class="@InputClass" />
                    </div>
                    <div>
                        <label class="@LabelClass">City</label>
                        <input type="text" @bind="city" placeholder="Brussels" class="@InputClass" />
                    </div>
                    <div>
                        <label class="@LabelClass">Postal code</label>
                        <input type="text" @bind="postalCode" placeholder="1000" class="@InputClass" />
                    </div>
                    <div>
                        <label class="@LabelClass">Country</label>
                        <select @bind="country" class="@InputClass">
                            <option value="">Select country</option>
                            <option value="BE">Belgium</option>
                            <option value="NL">Netherlands</option>
                            <option value="DE">Germany</option>
                            <option value="FR">France</option>
                            <option value="LU">Luxembourg</option>
                        </select>
                    </div>
                    <div>
                        <label class="@LabelClass">Phone (optional)</label>
                        <input type="tel" @bind="phone" placeholder="+32 XXX XX XX XX" class="@InputClass" />
                    </div>
                </div>

                <div class="mt-8 flex justify-end">
                    <button @onclick="NextStep" class="@PrimaryButtonClass">
                        Continue to Payment
                        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                        </svg>
                    </button>
                </div>
            </div>
        }

        @* ───── Step 1: Payment ───── *@
        @if (currentStep == 1)
        {
            <div class="bg-white border border-slate-200 rounded-2xl shadow-sm p-6 sm:p-8">
                <h2 class="text-lg font-bold text-slate-900 mb-6">Payment Method</h2>

                <!-- Payment options -->
                <div class="space-y-3 mb-8">
                    <label class="@PaymentOptionClass(paymentMethod == "card") flex items-center gap-4 p-4 rounded-xl border cursor-pointer transition-all">
                        <input type="radio" name="payment" value="card" @onchange='() => paymentMethod = "card"' checked="@(paymentMethod == "card")" class="sr-only" />
                        <div class="@PaymentRadioClass(paymentMethod == "card") w-5 h-5 rounded-full border-2 flex items-center justify-center shrink-0 transition-colors">
                            @if (paymentMethod == "card")
                            {
                                <div class="w-2.5 h-2.5 bg-emerald-600 rounded-full"></div>
                            }
                        </div>
                        <svg class="w-8 h-5 text-slate-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 0 0 2.25-2.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 4.5 19.5Z" />
                        </svg>
                        <div>
                            <span class="text-sm font-semibold text-slate-800">Credit / Debit Card</span>
                            <span class="text-xs text-slate-400 block">Visa, Mastercard, Amex</span>
                        </div>
                    </label>

                    <label class="@PaymentOptionClass(paymentMethod == "bancontact") flex items-center gap-4 p-4 rounded-xl border cursor-pointer transition-all">
                        <input type="radio" name="payment" value="bancontact" @onchange='() => paymentMethod = "bancontact"' checked="@(paymentMethod == "bancontact")" class="sr-only" />
                        <div class="@PaymentRadioClass(paymentMethod == "bancontact") w-5 h-5 rounded-full border-2 flex items-center justify-center shrink-0 transition-colors">
                            @if (paymentMethod == "bancontact")
                            {
                                <div class="w-2.5 h-2.5 bg-emerald-600 rounded-full"></div>
                            }
                        </div>
                        <svg class="w-8 h-5 text-slate-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0 0 12 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75Z" />
                        </svg>
                        <div>
                            <span class="text-sm font-semibold text-slate-800">Bancontact</span>
                            <span class="text-xs text-slate-400 block">Belgian debit payments</span>
                        </div>
                    </label>

                    <label class="@PaymentOptionClass(paymentMethod == "paypal") flex items-center gap-4 p-4 rounded-xl border cursor-pointer transition-all">
                        <input type="radio" name="payment" value="paypal" @onchange='() => paymentMethod = "paypal"' checked="@(paymentMethod == "paypal")" class="sr-only" />
                        <div class="@PaymentRadioClass(paymentMethod == "paypal") w-5 h-5 rounded-full border-2 flex items-center justify-center shrink-0 transition-colors">
                            @if (paymentMethod == "paypal")
                            {
                                <div class="w-2.5 h-2.5 bg-emerald-600 rounded-full"></div>
                            }
                        </div>
                        <svg class="w-8 h-5 text-slate-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a2.25 2.25 0 0 0-2.25-2.25H15a3 3 0 1 1-6 0H5.25A2.25 2.25 0 0 0 3 12m18 0v6a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 18v-6m18 0V9M3 12V9m18 0a2.25 2.25 0 0 0-2.25-2.25H5.25A2.25 2.25 0 0 0 3 9m18 0V6a2.25 2.25 0 0 0-2.25-2.25H5.25A2.25 2.25 0 0 0 3 6v3" />
                        </svg>
                        <div>
                            <span class="text-sm font-semibold text-slate-800">PayPal</span>
                            <span class="text-xs text-slate-400 block">Pay with your PayPal account</span>
                        </div>
                    </label>
                </div>

                <!-- Card details (shown only for card) -->
                @if (paymentMethod == "card")
                {
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 border-t border-slate-200 pt-6">
                        <div class="sm:col-span-2">
                            <label class="@LabelClass">Card number</label>
                            <input type="text" @bind="cardNumber" placeholder="4242 4242 4242 4242" maxlength="19" class="@InputClass font-mono" />
                        </div>
                        <div>
                            <label class="@LabelClass">Expiration</label>
                            <input type="text" @bind="cardExpiry" placeholder="MM / YY" maxlength="7" class="@InputClass font-mono" />
                        </div>
                        <div>
                            <label class="@LabelClass">CVC</label>
                            <input type="text" @bind="cardCvc" placeholder="123" maxlength="4" class="@InputClass font-mono" />
                        </div>
                        <div class="sm:col-span-2">
                            <label class="@LabelClass">Name on card</label>
                            <input type="text" @bind="cardName" placeholder="John Doe" class="@InputClass" />
                        </div>
                    </div>
                }

                <div class="mt-8 flex items-center justify-between">
                    <button @onclick="PreviousStep" class="@SecondaryButtonClass">
                        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
                        </svg>
                        Back
                    </button>
                    <button @onclick="NextStep" class="@PrimaryButtonClass">
                        Review Order
                        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                        </svg>
                    </button>
                </div>
            </div>
        }

        @* ───── Step 2: Review ───── *@
        @if (currentStep == 2)
        {
            <div class="space-y-6">

                <!-- Shipping summary -->
                <div class="bg-white border border-slate-200 rounded-2xl shadow-sm p-6">
                    <div class="flex items-center justify-between mb-4">
                        <h2 class="text-sm font-bold text-slate-500 uppercase tracking-widest">Shipping</h2>
                        <button @onclick="() => currentStep = 0" class="text-xs text-emerald-600 hover:text-emerald-700 font-semibold transition-colors">Edit</button>
                    </div>
                    <p class="text-sm text-slate-800 font-semibold">@firstName @lastName</p>
                    <p class="text-sm text-slate-500">@address</p>
                    <p class="text-sm text-slate-500">@postalCode @city, @country</p>
                    <p class="text-sm text-slate-500 mt-1">@email</p>
                </div>

                <!-- Payment summary -->
                <div class="bg-white border border-slate-200 rounded-2xl shadow-sm p-6">
                    <div class="flex items-center justify-between mb-4">
                        <h2 class="text-sm font-bold text-slate-500 uppercase tracking-widest">Payment</h2>
                        <button @onclick="() => currentStep = 1" class="text-xs text-emerald-600 hover:text-emerald-700 font-semibold transition-colors">Edit</button>
                    </div>
                    @if (paymentMethod == "card")
                    {
                        <p class="text-sm text-slate-800 font-semibold">Credit / Debit Card</p>
                        <p class="text-sm text-slate-500 font-mono">•••• •••• •••• @(cardNumber.Length >= 4 ? cardNumber[^4..] : "····")</p>
                    }
                    else
                    {
                        <p class="text-sm text-slate-800 font-semibold">@(paymentMethod == "bancontact" ? "Bancontact" : "PayPal")</p>
                    }
                </div>

                <!-- Items summary -->
                <div class="bg-white border border-slate-200 rounded-2xl shadow-sm p-6">
                    <h2 class="text-sm font-bold text-slate-500 uppercase tracking-widest mb-4">Items (@orderItems.Count)</h2>
                    <div class="divide-y divide-slate-100">
                        @foreach (var item in orderItems)
                        {
                            <div class="flex items-center gap-4 py-3">
                                <div class="w-12 h-12 bg-slate-100 rounded-lg shrink-0 flex items-center justify-center">
                                    <svg class="w-6 h-6 text-slate-300" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z" />
                                    </svg>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm font-semibold text-slate-800 truncate">@item.Name</p>
                                    <p class="text-xs text-slate-400">Qty: @item.Quantity</p>
                                </div>
                                <p class="text-sm font-bold text-slate-900 whitespace-nowrap">@((item.Price * item.Quantity).ToString("C"))</p>
                            </div>
                        }
                    </div>
                </div>

                <!-- Actions -->
                <div class="flex items-center justify-between pt-2">
                    <button @onclick="PreviousStep" class="@SecondaryButtonClass">
                        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
                        </svg>
                        Back
                    </button>
                    <button @onclick="PlaceOrder" disabled="@isPlacingOrder" class="@PrimaryButtonClass @(isPlacingOrder ? "opacity-70 cursor-not-allowed" : "")">
                        @if (isPlacingOrder)
                        {
                            <svg class="w-4 h-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                            </svg>
                            <span>Processing…</span>
                        }
                        else
                        {
                            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
                            </svg>
                            <span>Place Order — @Total.ToString("C")</span>
                        }
                    </button>
                </div>
            </div>
        }

        @* ───── Step 3: Confirmation ───── *@
        @if (currentStep == 3)
        {
            <div class="bg-white border border-slate-200 rounded-2xl shadow-sm p-8 sm:p-12 text-center">
                <div class="w-16 h-16 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-6">
                    <svg class="w-8 h-8 text-emerald-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                    </svg>
                </div>

                <h2 class="text-2xl font-extrabold text-slate-900">Order placed!</h2>
                <p class="mt-2 text-slate-500 max-w-md mx-auto">
                    Thank you for your purchase. We've sent a confirmation email to <span class="font-semibold text-slate-700">@email</span>.
                </p>

                <div class="mt-6 inline-flex items-center gap-2 bg-slate-50 border border-slate-200 px-5 py-3 rounded-xl">
                    <span class="text-xs text-slate-500 uppercase tracking-widest font-bold">Order</span>
                    <span class="text-sm font-bold text-slate-800 font-mono">#AW-@orderNumber</span>
                </div>

                <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-3">
                    <button @onclick='() => NavigationManager.NavigateTo("/orders")'
                            class="@PrimaryButtonClass">
                        View Orders
                    </button>
                    <button @onclick='() => NavigationManager.NavigateTo("/")'
                            class="@SecondaryButtonClass">
                        Continue Shopping
                    </button>
                </div>
            </div>
        }
    </div>

    <!-- Order Summary Sidebar (visible on steps 0–2) -->
    @if (currentStep < 3)
    {
        <aside class="w-full lg:w-80 shrink-0">
            <div class="bg-white border border-slate-200 rounded-2xl shadow-sm p-6 sticky top-6">
                <h2 class="text-sm font-bold text-slate-500 uppercase tracking-widest mb-5">Order Summary</h2>

                <!-- Mini items -->
                <div class="space-y-3 mb-5">
                    @foreach (var item in orderItems)
                    {
                        <div class="flex items-center justify-between gap-3 text-sm">
                            <div class="flex items-center gap-3 min-w-0">
                                <span class="w-6 h-6 bg-slate-100 rounded text-xs font-bold text-slate-500 flex items-center justify-center shrink-0">
                                    @item.Quantity
                                </span>
                                <span class="text-slate-700 truncate">@item.Name</span>
                            </div>
                            <span class="font-semibold text-slate-800 whitespace-nowrap">@((item.Price * item.Quantity).ToString("C"))</span>
                        </div>
                    }
                </div>

                <div class="border-t border-slate-200 pt-4 space-y-2 text-sm">
                    <div class="flex justify-between">
                        <span class="text-slate-500">Subtotal</span>
                        <span class="font-semibold text-slate-800">@Subtotal.ToString("C")</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-slate-500">Shipping</span>
                        <span class="font-semibold text-emerald-600">Free</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-slate-500">Tax</span>
                        <span class="font-semibold text-slate-800">@Tax.ToString("C")</span>
                    </div>
                </div>

                <div class="border-t border-slate-200 mt-4 pt-4 flex justify-between">
                    <span class="font-semibold text-slate-700">Total</span>
                    <span class="font-extrabold text-slate-900 text-lg">@Total.ToString("C")</span>
                </div>
            </div>
        </aside>
    }
</div>

@code {
    // ── Steps ──
    private static readonly string[] Steps = ["Shipping", "Payment", "Review", "Confirmation"];
    private int currentStep = 0;
    private bool isPlacingOrder;
    private string orderNumber = "";

    // ── Shipping ──
    private string email = "";
    private string firstName = "";
    private string lastName = "";
    private string address = "";
    private string city = "";
    private string postalCode = "";
    private string country = "";
    private string phone = "";

    // ── Payment ──
    private string paymentMethod = "card";
    private string cardNumber = "";
    private string cardExpiry = "";
    private string cardCvc = "";
    private string cardName = "";

    // ── Mock order items — replace with CartService ──
    private List<OrderItemViewModel> orderItems =
    [
        new() { Name = "Mountain Bike Pro 3000", Price = 899.99m, Quantity = 1 },
        new() { Name = "Cycling Helmet Ultra", Price = 59.99m, Quantity = 2 },
        new() { Name = "Carbon Fiber Water Bottle", Price = 24.99m, Quantity = 1 },
    ];

    private decimal Subtotal => orderItems.Sum(i => i.Price * i.Quantity);
    private decimal Tax => Math.Round(Subtotal * 0.21m, 2);
    private decimal Total => Subtotal + Tax;

    private void NextStep() => currentStep = Math.Min(currentStep + 1, Steps.Length - 1);
    private void PreviousStep() => currentStep = Math.Max(currentStep - 1, 0);

    private async Task PlaceOrder()
    {
        isPlacingOrder = true;
        StateHasChanged();

        // TODO: await OrderService.PlaceOrderAsync(...)
        await Task.Delay(1500); // simulate

        orderNumber = Random.Shared.Next(100000, 999999).ToString();
        isPlacingOrder = false;
        currentStep = 3;
    }

    // ── Styles ──
    private const string LabelClass = "block text-sm font-medium text-slate-700 mb-1.5";
    private const string InputClass = "w-full px-4 py-2.5 bg-white border border-slate-200 rounded-xl text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition";
    private const string PrimaryButtonClass = "px-6 py-3 bg-emerald-600 hover:bg-emerald-700 active:bg-emerald-800 text-white text-sm font-bold rounded-xl shadow-sm shadow-emerald-600/20 transition-all flex items-center gap-2";
    private const string SecondaryButtonClass = "px-5 py-3 bg-white border border-slate-200 hover:bg-slate-50 text-slate-700 text-sm font-semibold rounded-xl transition-colors flex items-center gap-2";

    private string StepBadgeClass(int index) => index < currentStep
        ? "bg-emerald-600 text-white"
        : index == currentStep
            ? "bg-emerald-100 text-emerald-700 border-2 border-emerald-400"
            : "bg-slate-100 text-slate-400";

    private string StepLabelClass(int index) => index <= currentStep
        ? "text-slate-800 font-semibold"
        : "text-slate-400";

    private string PaymentOptionClass(bool selected) => selected
        ? "border-emerald-400 bg-emerald-50/50"
        : "border-slate-200 hover:border-slate-300 bg-white";

    private string PaymentRadioClass(bool selected) => selected
        ? "border-emerald-600"
        : "border-slate-300";

    private class OrderItemViewModel
    {
        public string Name { get; set; } = "";
        public decimal Price { get; set; }
        public int Quantity { get; set; }
    }
}
