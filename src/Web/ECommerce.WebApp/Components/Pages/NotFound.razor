@page "/not-found"
@layout MainLayout
@inject NavigationManager NavigationManager

<PageTitle>Page Not Found — AdventureWorks</PageTitle>

<div class="flex flex-col items-center justify-center py-24 sm:py-32 text-center">

    <!-- 404 badge -->
    <div class="relative mb-8">
        <span class="text-[10rem] sm:text-[12rem] font-extrabold leading-none text-slate-100 select-none">
            404
        </span>
        <div class="absolute inset-0 flex items-center justify-center">
            <div class="w-20 h-20 bg-emerald-50 border border-emerald-200 rounded-full flex items-center justify-center">
                <svg class="w-10 h-10 text-emerald-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.182 16.318A4.486 4.486 0 0 0 12.016 15a4.486 4.486 0 0 0-3.198 1.318M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0ZM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75Zm-.375 0h.008v.015h-.008V9.75Zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75Zm-.375 0h.008v.015h-.008V9.75Z" />
                </svg>
            </div>
        </div>
    </div>

    <!-- Copy -->
    <h1 class="text-2xl sm:text-3xl font-extrabold text-slate-900 tracking-tight">
        Page not found
    </h1>
    <p class="mt-3 text-base text-slate-500 max-w-md">
        The page you're looking for doesn't exist or may have been moved. Let's get you back on track.
    </p>

    <!-- Actions -->
    <div class="mt-8 flex flex-col sm:flex-row items-center gap-3">
        <button @onclick="GoHome"
                class="px-6 py-3 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-bold rounded-xl shadow-sm shadow-emerald-600/20 hover:shadow-emerald-600/30 transition-all flex items-center gap-2">
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
            </svg>
            Back to Catalog
        </button>
        <button @onclick="GoBack"
                class="px-6 py-3 bg-white border border-slate-200 hover:bg-slate-50 text-slate-700 text-sm font-semibold rounded-xl transition-colors">
            Go Back
        </button>
    </div>
</div>

@code {
    private void GoHome() => NavigationManager.NavigateTo("/");

    private void GoBack()
    {
        // JS interop fallback: history.back()
        NavigationManager.NavigateTo("/");
    }
}
