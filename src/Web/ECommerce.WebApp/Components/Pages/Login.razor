@page "/login"
@using ECommerce.WebApp.Features.Authentication.Providers
@using System.ComponentModel.DataAnnotations
@inject TokenAuthStateProvider AuthState
@inject NavigationManager Navigation

<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card shadow-sm" style="width: 100%; max-width: 420px;">
        <div class="card-body p-4">
            <h3 class="card-title text-center mb-1">Welcome back</h3>
            <p class="text-muted text-center mb-4">Sign in to your account</p>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @_errorMessage
                    <button type="button" class="btn-close" @onclick="() => _errorMessage = null"></button>
                </div>
            }

            <EditForm Model="_model" OnValidSubmit="HandleLogin" FormName="LoginForm" Enhance>
                <DataAnnotationsValidator />

                <div class="mb-3">
                    <label for="email" class="form-label">Email address</label>
                    <InputText id="email" class="form-control" @bind-Value="_model.Email"
                               placeholder="name@example.com" />
                    <ValidationMessage For="() => _model.Email" class="text-danger small" />
                </div>

                <div class="mb-3">
                    <label for="password" class="form-label">Password</label>
                    <InputText id="password" type="password" class="form-control"
                               @bind-Value="_model.Password" placeholder="••••••••" />
                    <ValidationMessage For="() => _model.Password" class="text-danger small" />
                </div>

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="form-check">
                        <InputCheckbox id="remember" class="form-check-input"
                                       @bind-Value="_model.RememberMe" />
                        <label for="remember" class="form-check-label small">Remember me</label>
                    </div>
                    <a href="/forgot-password" class="small text-decoration-none">Forgot password?</a>
                </div>

                <button type="submit" class="btn btn-primary w-100" disabled="@_isLoading">
                    @if (_isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        <span>Signing in...</span>
                    }
                    else
                    {
                        <span>Sign in</span>
                    }
                </button>
            </EditForm>

            <hr class="my-4" />

            <p class="text-center text-muted small mb-0">
                Don't have an account?
                <a href="/register" class="text-decoration-none">Create one</a>
            </p>
        </div>
    </div>
</div>

@code {
    private LoginModel _model = new();
    private string? _errorMessage;
    private bool _isLoading;

    private async Task HandleLogin()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            var result = await AuthState.LoginAsync(_model.Email, _model.Password);

            if (result?.RequiresTwoFactor == true)
            {
                Navigation.NavigateTo($"/login/2fa?token={Uri.EscapeDataString(result.LimitedToken!)}");
                return;
            }

            if (result?.AccessTokens is not null)
            {
                Navigation.NavigateTo("/");
            }
        }
        catch (HttpRequestException)
        {
            _errorMessage = "Invalid email or password. Please try again.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private sealed class LoginModel
    {
        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Invalid email format.")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Password is required.")]
        public string Password { get; set; } = "";

        public bool RememberMe { get; set; }
    }
}